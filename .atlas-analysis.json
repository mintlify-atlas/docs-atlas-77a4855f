  "keyFeatures": [
    "Unified media board with personalized content recommendations",
    "Discover and browse catalogs from multiple streaming addons",
    "Full-featured video player with subtitles, audio tracks, and statistics",
    "Personal library and continue-watching tracking",
    "Addon system supporting movies, series, channels, TV, music, podcasts, and more",
    "Chromecast support for casting to TV devices",
    "Keyboard shortcuts for power users",
    "Torrent and magnet link support via streaming server",
    "Multi-language i18n support",
    "Progressive Web App (PWA) with installable manifest",
    "Docker deployment support",
    "Calendar view for release scheduling"
  ],
  "publicApiSurface": [
    "GET /board — Home screen with recommended catalogs",
    "GET /discover/:transportUrl/:type/:catalogId — Browse addon catalogs",
    "GET /library/:type — Personal media library",
    "GET /calendar/:year/:month — Calendar view of scheduled releases",
    "GET /search — Search across all installed addons",
    "GET /metadetails/:type/:id/:videoId — Media detail page with streams",
    "GET /player/:stream — Full video player with controls",
    "GET /addons/:type/:transportUrl/:catalogId — Addon management",
    "GET /settings — Application settings",
    "GET /intro — Onboarding introduction screen",
    "GET /continuewatching/:type — Continue watching list"
  ]
